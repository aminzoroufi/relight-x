{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Install PlatformIO Core",
      "type": "shell",
      "command": "python3",
      "args": [
        "tools/run_platformio.py",
        "--install"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Build Wokwi firmware",
      "type": "shell",
      "command": "python3",
      "args": [
        "tools/run_platformio.py",
        "run"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": "$gcc"
    },
    {
      "label": "Clean Wokwi firmware",
      "type": "shell",
      "command": "python3",
      "args": [
        "tools/run_platformio.py",
        "run",
        "--target",
        "clean"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    }
  ]
}
